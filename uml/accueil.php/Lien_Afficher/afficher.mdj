							"text": "\t    👉OBJET:   Affichage de document dans la page d'accueil(via 1 popup)\n\t    👉CIBLE:   SERVEUR/colonne_afficher_naissance.php\n            👉CHEMIN: accueil.php\n\t\t                 -> include(\"inc/accueil/accueil_prefecture.php\")\n\t\t                 -> include(\"inc/accueil/accueil_choisir_naissance.php\")\n                            -> capture_items.js : onchange=captureCombo(this.value);\n                            -> xmlhttp.open(\"GET\",\"SERVEUR/colonne_afficher_naissance.php?p=\"+str,true);"
